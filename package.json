{
  "name": "booking-service-typespec",
  "version": "0.1.0",
  "private": true,
  "description": "TypeSpec API contract for the booking service (Cal.com-like).",
  "scripts": {
    "build": "tsp compile tsp",
    "watch": "tsp compile tsp --watch",
    "lint": "redocly lint tsp-output/openapi.yaml",
    "mock": "node node_modules/@stoplight/prism-cli/dist/index.js mock --dynamic tsp-output/openapi.yaml",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@redocly/cli": "^1.25.0",
    "@stoplight/prism-cli": "5.14.2",
    "@typespec/compiler": "^1.0.0",
    "@typespec/http": "^1.0.0",
    "@typespec/openapi": "^1.0.0",
    "@typespec/openapi3": "^1.0.0"
  },
  "overrides": {
    "@stoplight/prism-cli": "5.14.2",
    "@stoplight/prism-core": "5.8.0",
    "@stoplight/prism-http": "5.12.0",
    "@stoplight/prism-http-server": "5.12.2"
  }
}
